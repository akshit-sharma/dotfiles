#!/bin/bash
# configuration file synced across devices
# don't make any system specific changes in this
# system specific changes goes in ~/.my_vars

git -C $HOME/dotfiles remote update

UPSTREAM=${1:-'@{u}'}
#' small work around for cleaner syntax in vim
LOCAL=$(git -C $HOME/dotfiles rev-parse @)
REMOTE=$(git -C $HOME/dotfiles rev-parse "$UPSTREAM")
BASE=$(git -C $HOME/dotfiles merge-base @ "$UPSTREAM")

if [ $LOCAL = $BASE ]; then
 
  echo "Need to pull"
  
  git -C $HOME/dotfiles pull origin master
  source $HOME/dotfiles/update.sh "PROFILE_REFRESH" "VIM_PLUGIN_REFRESH"

elif [ $REMOTE = $BASE ] | [ $LOCAL = $REMOTE ]; then

  if [ $REMOTE = $BASE ]; then 
    echo "Need to push"
    git -C $HOME/dotfiles push origin master
  else 
    echo "Up-to-date"
  fi
  clear
 
  PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]\u\[\033[00m\]:\[\033[01;34m\]\W\[\033[00m\]\$ '

  alias vir='vi -R'
  alias vr='vi -R'

  source $HOME/.my_vars
  
  export PS1

else
  
  echo "Diverged"

fi

